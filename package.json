    "test": "vitest run",
    "gen:manifest": "node scripts/gen_image_manifest.mjs",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.5.3",
    "vite": "^5.4.0",
    "vite-plugin-singlefile": "^2.0.2",
    "vitest": "^2.0.5",
    "wrangler": "^4.0.0"
  }
}
