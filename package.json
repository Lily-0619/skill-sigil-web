{
  "name": "skill-sigil-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "sync:public-images": "node scripts/sync_public_images.mjs",
    "build": "npm run sync:public-images && tsc --noEmit && vite build",
